      "metadata": {
        "id": "lgd-hZkrz06t"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "plt.figure(figsize=(10,5))\n",
        "plt.plot(ts_data[-100:], label=\"Actual\")\n",
        "plt.plot(forecast, label=\"Forecast\", color='red')\n",
        "plt.legend()\n",
        "plt.title(\"Sales Forecast (ARIMA)\")\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 468
        },
        "id": "Du_ZCXOdKfWA",
