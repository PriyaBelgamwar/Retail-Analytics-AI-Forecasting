            "\n",
            "[5 rows x 23 columns]\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "#####I extracted temporal features to capture seasonality and trends in sales"
      ],
      "metadata": {
        "id": "1Xq4YhcLx57O"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Weekend Flag**"
      ],
      "metadata": {
        "id": "adJZEifdyBqV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df['Is_Weekend'] = df['Weekday'].isin(['Saturday', 'Sunday']).astype(int)"
      ],
      "metadata": {
        "id": "-Arscs6RAfZ2"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "**First Plot:** Sales Over Time"
      ],
      "metadata": {
        "id": "jTkBYZ2ZyGVq"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Group by date\n",
        "sales_trend = df.groupby('Date')['Total_Sales'].sum()\n",
        "\n",
        "plt.figure(figsize=(12,5))\n",
        "plt.plot(sales_trend)\n",
        "plt.title(\"Total Sales Over Time\")\n",
        "plt.xlabel(\"Date\")\n",
        "plt.ylabel(\"Sales\")\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 487
        },
        "id": "SNlBFPdEAmC9",
        "outputId": "43877223-d409-4753-8d68-dc373d25f95b"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1200x500 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Second Plot**: Monthly Sales"
      ],
      "metadata": {
        "id": "nMWbJkZPyQUu"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "monthly_sales = df.groupby('Month')['Total_Sales'].sum()\n",
        "\n",
        "monthly_sales.plot(kind='bar', title=\"Monthly Sales\")\n",
        "plt.show()"
      ],
      "metadata": {
        "id": "5QTo0pg4AufE",
        "outputId": "a70fa459-d178-4b9d-d244-f943077d6419",
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 475
        }
      },
      "execution_count": null,
