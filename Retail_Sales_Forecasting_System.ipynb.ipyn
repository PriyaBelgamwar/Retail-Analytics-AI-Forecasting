          },
          "metadata": {}
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Third Plot:** Category-wise Sales"
      ],
      "metadata": {
        "id": "ZaXvrw2JyXRJ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "category_sales = df.groupby('Product_Category')['Total_Sales'].sum()\n",
        "\n",
        "category_sales.plot(kind='bar')\n",
        "plt.title(\"Sales by Category\")\n",
        "plt.xticks(rotation=45)\n",
        "plt.show()"
      ],
      "metadata": {
        "id": "V5SgqAdrAxeB",
        "outputId": "6f1cacd7-8e15-4e59-8dd0-6517457d2ca1",
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 553
        }
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
