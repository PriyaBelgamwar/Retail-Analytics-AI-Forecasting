    {
      "cell_type": "markdown",
      "source": [
        "Prediction + Evaluation"
      ],
      "metadata": {
        "id": "opjTmu6Ay5GS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.metrics import mean_absolute_error, mean_squared_error\n",
        "import numpy as np\n",
        "\n",
        "y_pred = model.predict(X_test)\n",
        "\n",
        "mae = mean_absolute_error(y_test, y_pred)\n",
        "rmse = np.sqrt(mean_squared_error(y_test, y_pred))\n",
        "\n",
        "print(\"MAE:\", mae)\n",
        "print(\"RMSE:\", rmse)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "gAcoqkjzFEul",
        "outputId": "e0db2916-4daf-4fa7-f46a-f8e3630f50f8"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "MAE: 655.7916509178038\n",
            "RMSE: 1038.570942169426\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Store Segmentation**"
      ],
      "metadata": {
        "id": "56ovlVymzOuX"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.cluster import KMeans\n",
        "\n",
        "# Create store-level dataset\n",
        "store_data = df.groupby('Store_ID').agg({\n",
        "    'Total_Sales': 'sum',\n",
        "    'Units_Sold': 'sum'\n",
        "}).reset_index()\n",
        "\n",
        "# Apply KMeans\n",
        "kmeans = KMeans(n_clusters=3, random_state=42)\n",
        "store_data['Cluster'] = kmeans.fit_predict(store_data[['Total_Sales', 'Units_Sold']])\n",
        "\n",
        "print(store_data.head())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "wfGm9aDmFjDT",
        "outputId": "dffd8fb7-219e-434c-95e3-518fc29435e4"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "  Store_ID   Total_Sales  Units_Sold  Cluster\n",
            "0  STR_101  2.447965e+09     96754.0        0\n",
            "1  STR_102  2.415826e+09     95601.0        2\n",
            "2  STR_103  2.455956e+09     98204.0        0\n",
            "3  STR_104  2.467243e+09     96934.0        0\n",
            "4  STR_105  2.356311e+09     93610.0        1\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Visualize Clusters**"
      ],
      "metadata": {
        "id": "jM2VzbJ4zTwD"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "plt.scatter(store_data['Total_Sales'], store_data['Units_Sold'], c=store_data['Cluster'])\n",
        "plt.xlabel(\"Total Sales\")\n",
        "plt.ylabel(\"Units Sold\")\n",
        "plt.title(\"Store Segmentation\")\n",
        "plt.show()"
      ],
      "metadata": {
