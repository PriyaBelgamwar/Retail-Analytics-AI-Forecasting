      "source": [
        "import pandas as pd\n",
        "\n",
        "# Load dataset\n",
        "df = pd.read_csv(\"Retail_Sales_Data_Unlox (1).csv\")\n",
        "\n",
        "# View first 5 rows\n",
        "print(df.head())\n",
        "\n",
        "# Check columns\n",
        "print(\"\\nColumns:\")\n",
        "print(df.columns)\n",
        "\n",
        "# Check data types\n",
        "print(\"\\nData Types:\")\n",
        "print(df.dtypes)\n",
        "\n",
        "# Check missing values\n",
        "print(\"\\nMissing Values:\")\n",
        "print(df.isnull().sum())\n",
        "\n",
        "# Basic info\n",
        "print(\"\\nInfo:\")\n",
        "print(df.info())"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**The dataset contains transactional retail data with multiple features such as store details, product categories, pricing, and sales metrics. No missing values are observed, ensuring data quality for further analysis.**"
      ],
      "metadata": {
        "id": "nPLhkrkCsdH6"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Data Cleaning + Feature Engineering**"
      ],
      "metadata": {
        "id": "-CoQpcEPswiD"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Convert Date to datetime\n",
        "df['Date'] = pd.to_datetime(df['Date'])\n",
        "\n",
        "# Create new time-based features\n",
        "df['Year'] = df['Date'].dt.year\n",
        "df['Month'] = df['Date'].dt.month\n",
        "df['Day'] = df['Date'].dt.day\n",
        "df['Weekday'] = df['Date'].dt.day_name()\n",
        "\n",
        "print(df.head())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "COMRjUafAbLU",
        "outputId": "a42da657-e924-4b1f-f963-b172f09e119c"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "        Date Store_ID Store_Location Product_ID Product_Category  \\\n",
