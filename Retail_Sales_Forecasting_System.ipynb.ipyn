    {
      "cell_type": "markdown",
      "source": [
        "**Business Recommended Engine**"
      ],
      "metadata": {
        "id": "SNTo8HL2zgKV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def generate_recommendations():\n",
        "    recommendations = []\n",
        "\n",
        "    # High sales months\n",
        "    recommendations.append(\"Increase inventory and marketing during peak months like March and August.\")\n",
        "\n",
        "    # Category insight\n",
        "    recommendations.append(\"Maintain balanced investment across categories as all contribute significantly.\")\n",
        "\n",
        "    # Store segmentation\n",
        "    recommendations.append(\"Focus on improving low-performing stores through targeted promotions and offers.\")\n",
        "\n",
        "    # Pricing & discount\n",
        "    recommendations.append(\"Optimize discount strategies to maximize revenue without heavy margin loss.\")\n",
        "\n",
        "    # Weekend strategy\n",
        "    recommendations.append(\"Leverage weekend sales by running special campaigns and promotions.\")\n",
        "\n",
        "    return recommendations\n",
        "\n",
        "\n",
        "recs = generate_recommendations()\n",
        "\n",
        "for i, rec in enumerate(recs, 1):\n",
        "    print(f\"{i}. {rec}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "fEkt6JfVGEzG",
        "outputId": "7d652a7e-53bf-4599-cdd0-625609911fe0"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "1. Increase inventory and marketing during peak months like March and August.\n",
            "2. Maintain balanced investment across categories as all contribute significantly.\n",
            "3. Focus on improving low-performing stores through targeted promotions and offers.\n",
            "4. Optimize discount strategies to maximize revenue without heavy margin loss.\n",
            "5. Leverage weekend sales by running special campaigns and promotions.\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Time-Series Forcast**"
      ],
      "metadata": {
        "id": "rXEun2JZztI1"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from statsmodels.tsa.arima.model import ARIMA\n",
        "\n",
        "# Aggregate daily sales\n",
        "ts_data = df.groupby('Date')['Total_Sales'].sum()\n",
        "\n",
        "# Fit ARIMA model\n",
        "model_arima = ARIMA(ts_data, order=(1,1,1))\n",
        "model_arima_fit = model_arima.fit()\n",
        "\n",
        "# Forecast next 30 days\n",
        "forecast = model_arima_fit.forecast(steps=30)\n",
        "\n",
        "print(forecast)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
